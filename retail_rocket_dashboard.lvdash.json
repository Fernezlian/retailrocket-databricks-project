{
  "datasets": [
    {
      "name": "3639af28",
      "displayName": "Hourly Event Totals Summary from Retail Rocket Data",
      "queryLines": [
        "USE CATALOG `retail_rocket`;\n",
        "USE SCHEMA `db`;\n",
        "\n",
        "SELECT \n",
        "  hour,\n",
        "  event,\n",
        "  COUNT(*) AS total_events\n",
        "FROM events_silver\n",
        "GROUP BY hour, event\n",
        "ORDER BY hour;"
      ]
    },
    {
      "name": "64f2f5c3",
      "displayName": "User Interaction Events Summary Retail Rocket",
      "queryLines": [
        "USE CATALOG `retail_rocket`;\n",
        "USE SCHEMA `db`;\n",
        "\n",
        "SELECT \n",
        "  COUNT(CASE WHEN event = 'view' THEN 1 END) AS views,\n",
        "  COUNT(CASE WHEN event = 'addtocart' THEN 1 END) AS add_to_cart,\n",
        "  COUNT(CASE WHEN event = 'transaction' THEN 1 END) AS purchases,\n",
        "\n",
        "  COUNT(CASE WHEN event = 'addtocart' THEN 1 END) * 100.0 /\n",
        "  COUNT(CASE WHEN event = 'view' THEN 1 END) AS cart_rate,\n",
        "\n",
        "  COUNT(CASE WHEN event = 'transaction' THEN 1 END) * 100.0 /\n",
        "  COUNT(CASE WHEN event = 'addtocart' THEN 1 END) AS purchase_rate\n",
        "\n",
        "FROM events_silver;"
      ]
    },
    {
      "name": "af25d0a4",
      "displayName": "Top Ten Items Ranked by Views Adds and Purchases",
      "queryLines": [
        "USE CATALOG `retail_rocket`;\n",
        "USE SCHEMA `db`;\n",
        "\n",
        "SELECT\n",
        "  itemid,\n",
        "  COUNT(CASE WHEN event = 'view' THEN 1 END) AS views,\n",
        "  COUNT(CASE WHEN event = 'addtocart' THEN 1 END) AS adds,\n",
        "  COUNT(CASE WHEN event = 'transaction' THEN 1 END) AS purchases,\n",
        "  ROUND(\n",
        "    (COUNT(CASE WHEN event = 'transaction' THEN 1 END) * 100.0) /\n",
        "    NULLIF(COUNT(CASE WHEN event = 'view' THEN 1 END), 0), \n",
        "    2\n",
        "  ) AS purchase_rate\n",
        "\n",
        "FROM retail_rocket.db.events_silver\n",
        "GROUP BY itemid\n",
        "HAVING views > 1000\n",
        "ORDER BY purchase_rate DESC\n",
        "LIMIT 10;"
      ]
    }
  ],
